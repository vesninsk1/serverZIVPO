									"    var jsonData = pm.response.json();",
									"    if (jsonData.code) {",
									"        pm.environment.set(\"licenseCode\", jsonData.code);",
									"    } else if (jsonData.licenseCode) {",
									"        pm.environment.set(\"licenseCode\", jsonData.licenseCode);",
